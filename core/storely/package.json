{
	"name": "@ambicuity/storely",
	"version": "1.0.0",
	"description": "Simple key-value storage with support for multiple backends (Storely)",
	"type": "module",
	"main": "./dist/index.mjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"browser": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			},
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		}
	},
	"sideEffects": false,
	"scripts": {
		"build": "tsdown",
		"prepublishOnly": "pnpm build",
		"lint": "biome check --write --error-on-warnings",
		"lint:ci": "biome check --error-on-warnings",
		"test": "pnpm lint && vitest run --coverage",
		"test:browser": "vitest run --config vitest.browser.config.ts",
		"test:ci": "pnpm lint:ci && vitest --run --sequence.setupFiles=list --coverage",
		"clean": "rimraf ./node_modules ./coverage ./test/testdb.sqlite ./dist"
	},
	"keywords": [
		"key",
		"value",
		"store",
		"cache",
		"ttl",
		"key-value",
		"storage",
		"backend",
		"adapter",
		"redis",
		"mongodb",
		"sqlite",
		"mysql",
		"postgresql",
		"memory",
		"node-cache",
		"lru-cache",
		"lru",
		"cache-manager",
		"browser"
	],
	"license": "MIT",
	"dependencies": {
		"hookified": "^2.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.13",
		"@faker-js/faker": "^10.2.0",
		"@vitest/coverage-v8": "^4.0.18",
		"happy-dom": "^20.8.7",
		"lru.min": "^1.1.1",
		"quick-lru": "^7.0.0",
		"rimraf": "^6.1.2",
		"timekeeper": "^2.3.1",
		"tsd": "^0.33.0",
		"vitest": "^4.0.18"
	},
	"tsd": {
		"directory": "test"
	},
	"files": [
		"dist",
		"LICENSE"
	]
}
