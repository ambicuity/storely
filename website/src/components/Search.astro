---
/**
 * Custom search modal that talks to Pagefind's programmatic API and renders
 * results in the editorial type system. The Pagefind UI library is avoided
 * because its default styling fights the cream/oxblood/Instrument-Serif POV.
 *
 * The index lives at /pagefind/pagefind.js — generated by `pagefind --site dist`
 * at the end of `pnpm website:build`. In `astro dev` the index isn't built; the
 * modal still opens and shows a build hint instead of staying blank.
 */
---

<button
	type="button"
	class="search-trigger"
	id="search-open"
	aria-haspopup="dialog"
	aria-label="Search the documentation"
>
	<svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
		<circle cx="7" cy="7" r="4" stroke="currentColor" stroke-width="1.4" fill="none" />
		<line x1="10.5" y1="10.5" x2="13.5" y2="13.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
	</svg>
	<span class="label">Search</span>
	<kbd>⌘ K</kbd>
</button>

<div
	class="search-dialog"
	id="search-dialog"
	hidden
	role="dialog"
	aria-modal="true"
	aria-labelledby="search-title"
>
	<div class="scrim" data-search-close aria-hidden="true"></div>
	<div class="panel">
		<header>
			<div class="title-row">
				<svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
					<circle cx="7" cy="7" r="4" stroke="currentColor" stroke-width="1.4" fill="none" />
					<line x1="10.5" y1="10.5" x2="13.5" y2="13.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
				</svg>
				<h2 id="search-title">Search the index</h2>
			</div>
			<button type="button" data-search-close aria-label="Close search">
				<svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
					<path d="M3 3l10 10M13 3L3 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
				</svg>
				<kbd>Esc</kbd>
			</button>
		</header>

		<div class="input-row">
			<input
				type="search"
				id="search-input"
				placeholder="Adapters, hooks, encryption…"
				autocomplete="off"
				autocorrect="off"
				autocapitalize="off"
				spellcheck="false"
				aria-controls="search-results"
				aria-describedby="search-status"
			/>
			<span id="search-status" class="status" role="status" aria-live="polite"></span>
		</div>

		<div class="results-region">
			<ul
				id="search-results"
				role="listbox"
				aria-label="Search results"
				hidden
			></ul>

			<div class="state state-idle" data-state="idle">
				<p class="hint-title">Start typing.</p>
				<p class="hint-body">
					Try <button type="button" class="chip" data-prefill="redis">redis</button>,
					<button type="button" class="chip" data-prefill="namespace">namespace</button>,
					<button type="button" class="chip" data-prefill="ttl">ttl</button>,
					<button type="button" class="chip" data-prefill="encryption">encryption</button>.
				</p>
			</div>

			<div class="state state-empty" data-state="empty" hidden>
				<p class="hint-title">No matches.</p>
				<p class="hint-body" id="empty-detail"></p>
			</div>

			<div class="state state-unavailable" data-state="unavailable" hidden>
				<p class="hint-title">Search index isn't built yet.</p>
				<p class="hint-body">
					Run <code>pnpm website:build</code> to produce <code>dist/pagefind/</code> and
					reload. The dev server doesn't generate the index on the fly.
				</p>
			</div>
		</div>

		<footer class="legend" aria-hidden="true">
			<span><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
			<span><kbd>⏎</kbd> open</span>
			<span><kbd>Esc</kbd> close</span>
		</footer>
	</div>
</div>

<script>
	interface PagefindResultData {
		url: string;
		raw_url?: string;
		excerpt: string;
		meta: { title?: string };
		filters?: Record<string, string[]>;
	}
	interface PagefindResult {
		id: string;
		score: number;
		data: () => Promise<PagefindResultData>;
	}
	interface PagefindModule {
		search: (
			query: string,
			options?: Record<string, unknown>,
		) => Promise<{ results: PagefindResult[] }>;
		options?: (opts: Record<string, unknown>) => Promise<void>;
	}

	const trigger = document.getElementById("search-open");
	const dialog = document.getElementById("search-dialog");
	const input = document.getElementById("search-input") as HTMLInputElement | null;
	const list = document.getElementById("search-results") as HTMLUListElement | null;
	const status = document.getElementById("search-status");
	const emptyDetail = document.getElementById("empty-detail");

	if (!(trigger && dialog && input && list && status)) {
		console.warn("[storely] Search wiring skipped — missing elements", {
			trigger: !!trigger,
			dialog: !!dialog,
			input: !!input,
			list: !!list,
			status: !!status,
		});
	}

	if (trigger && dialog && input && list && status) {
		let pagefindPromise: Promise<PagefindModule | null> | null = null;
		const loadPagefind = (): Promise<PagefindModule | null> => {
			if (!pagefindPromise) {
				pagefindPromise = import(
					/* @vite-ignore */ `${window.location.origin}/pagefind/pagefind.js`
				)
					.then((m) => m as PagefindModule)
					.catch(() => null);
			}
			return pagefindPromise;
		};

		const setState = (state: "idle" | "empty" | "unavailable" | "results") => {
			dialog
				.querySelectorAll<HTMLElement>(".state")
				.forEach((el) => {
					el.hidden = el.dataset.state !== state;
				});
			if (list) list.hidden = state !== "results";
		};

		let debounce: number | undefined;
		let activeIdx = -1;
		let resultsCache: PagefindResultData[] = [];

		const render = (results: PagefindResultData[]) => {
			resultsCache = results;
			list.innerHTML = "";
			activeIdx = -1;
			results.forEach((r, i) => {
				const li = document.createElement("li");
				li.setAttribute("role", "option");
				li.dataset.idx = String(i);
				const a = document.createElement("a");
				a.href = r.url;
				a.tabIndex = -1;

				const meta = document.createElement("span");
				meta.className = "result-meta";
				meta.textContent = sectionFromUrl(r.url);

				const title = document.createElement("span");
				title.className = "result-title";
				title.textContent = r.meta?.title ?? r.url;

				const excerpt = document.createElement("span");
				excerpt.className = "result-excerpt";
				excerpt.innerHTML = r.excerpt;

				const path = document.createElement("span");
				path.className = "result-path";
				path.textContent = r.url.replace(/^\//, "").replace(/\/$/, "") || "/";

				a.append(meta, title, excerpt, path);
				li.appendChild(a);
				list.appendChild(li);
			});
			if (results.length > 0) {
				setState("results");
				setActive(0);
			}
		};

		const sectionFromUrl = (url: string): string => {
			const seg = url.split("/").filter(Boolean)[0];
			if (!seg) return "Home";
			if (seg === "docs") return "Docs";
			if (seg === "adapters") return "Adapter";
			if (seg === "guides") return "Guide";
			if (seg === "third-party") return "Project";
			return seg.charAt(0).toUpperCase() + seg.slice(1);
		};

		const setActive = (idx: number) => {
			const items = list.querySelectorAll<HTMLLIElement>("li");
			items.forEach((el) => el.classList.remove("active"));
			activeIdx = Math.max(0, Math.min(idx, items.length - 1));
			const el = items[activeIdx];
			if (el) {
				el.classList.add("active");
				el.scrollIntoView({ block: "nearest" });
			}
		};

		const runSearch = async (raw: string) => {
			const query = raw.trim();
			if (!query) {
				setState("idle");
				status.textContent = "";
				return;
			}
			status.textContent = "Searching…";
			const pagefind = await loadPagefind();
			if (!pagefind) {
				setState("unavailable");
				status.textContent = "";
				return;
			}
			try {
				const r = await pagefind.search(query);
				const top = await Promise.all(r.results.slice(0, 8).map((x) => x.data()));
				if (top.length === 0) {
					if (emptyDetail) {
						emptyDetail.textContent = `Nothing matched "${query}". Try a broader term — adapter, namespace, ttl.`;
					}
					setState("empty");
					status.textContent = "0 results";
				} else {
					render(top);
					status.textContent = `${top.length} result${top.length === 1 ? "" : "s"}`;
				}
			} catch {
				setState("unavailable");
				status.textContent = "";
			}
		};

		input.addEventListener("input", () => {
			window.clearTimeout(debounce);
			debounce = window.setTimeout(() => {
				void runSearch(input.value);
			}, 130);
		});

		input.addEventListener("keydown", (e) => {
			const items = list.querySelectorAll<HTMLLIElement>("li");
			if (e.key === "ArrowDown") {
				e.preventDefault();
				setActive(activeIdx + 1);
			} else if (e.key === "ArrowUp") {
				e.preventDefault();
				setActive(activeIdx - 1);
			} else if (e.key === "Enter") {
				const el = items[activeIdx];
				const link = el?.querySelector("a");
				if (link) {
					window.location.href = link.href;
				}
			}
		});

		dialog
			.querySelectorAll<HTMLButtonElement>("[data-prefill]")
			.forEach((btn) =>
				btn.addEventListener("click", () => {
					input.value = btn.dataset.prefill ?? "";
					void runSearch(input.value);
					input.focus();
				}),
			);

		const focusableInDialog = (): HTMLElement[] => {
			const selectors = [
				'a[href]',
				'button:not([disabled])',
				'input:not([disabled])',
				'[tabindex]:not([tabindex="-1"])',
			].join(",");
			return Array.from(dialog.querySelectorAll<HTMLElement>(selectors));
		};

		const trapFocus = (e: KeyboardEvent) => {
			if (e.key !== "Tab") return;
			const items = focusableInDialog();
			if (items.length === 0) return;
			const first = items[0];
			const last = items[items.length - 1];
			const active = document.activeElement as HTMLElement | null;
			if (e.shiftKey && active === first) {
				e.preventDefault();
				last.focus();
			} else if (!e.shiftKey && active === last) {
				e.preventDefault();
				first.focus();
			}
		};

		const onDialogKeydown = (e: KeyboardEvent) => {
			if (e.key === "Escape") {
				e.preventDefault();
				close();
				return;
			}
			trapFocus(e);
		};

		const open = async () => {
			dialog.hidden = false;
			document.documentElement.style.overflow = "hidden";
			input.value = "";
			setState("idle");
			status.textContent = "";
			dialog.addEventListener("keydown", onDialogKeydown);
			requestAnimationFrame(() => input.focus());
			// Warm the index in the background so the first keystroke feels instant.
			void loadPagefind();
		};

		const close = () => {
			dialog.hidden = true;
			document.documentElement.style.overflow = "";
			dialog.removeEventListener("keydown", onDialogKeydown);
			trigger.focus();
		};

		trigger.addEventListener("click", () => {
			void open();
		});

		dialog
			.querySelectorAll<HTMLElement>("[data-search-close]")
			.forEach((el) =>
				el.addEventListener("click", (e) => {
					e.preventDefault();
					close();
				}),
			);

		document.addEventListener("keydown", (e) => {
			const meta = e.metaKey || e.ctrlKey;
			if (meta && e.key.toLowerCase() === "k") {
				e.preventDefault();
				if (dialog.hidden) {
					void open();
				} else {
					close();
				}
			}
		});
	}
</script>

<style>
	.search-trigger {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.4rem 0.7rem 0.4rem 0.6rem;
		font-family: var(--font-body);
		font-size: var(--step--1);
		color: var(--ink-soft);
		background: transparent;
		border: 1px solid var(--rule);
		border-radius: 2px;
		transition: color var(--dur-fast) var(--ease-out),
			border-color var(--dur-fast) var(--ease-out),
			background var(--dur-fast) var(--ease-out);
	}

	.search-trigger:hover {
		color: var(--accent);
		border-color: var(--accent);
		background: var(--canvas-soft);
	}

	.search-trigger .label {
		font-family: var(--font-display);
		font-style: italic;
		font-size: var(--step-0);
	}

	.search-trigger kbd {
		font-family: var(--font-mono);
		font-size: var(--step--2);
		color: var(--ink-faint);
		background: var(--canvas-soft);
		padding: 0.1rem 0.4rem;
		border-radius: 2px;
		letter-spacing: 0.06em;
	}

	@media (max-width: 720px) {
		.search-trigger .label,
		.search-trigger kbd {
			display: none;
		}
		.search-trigger {
			padding: 0.45rem;
		}
	}

	.search-dialog {
		position: fixed;
		inset: 0;
		z-index: 100;
		display: grid;
		place-items: start center;
		padding: clamp(2rem, 6vw, 5rem) var(--margin) var(--margin);
		isolation: isolate;
		animation: fade-in var(--dur) var(--ease-out);
	}

	/*
	 * The HTML `hidden` attribute sets `display: none`, but our `display: grid`
	 * rule above wins on specificity, so the dialog stays visible. Force it
	 * closed explicitly. Without this, the modal never hides.
	 */
	.search-dialog[hidden] {
		display: none !important;
	}

	@keyframes fade-in {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	.scrim {
		position: absolute;
		inset: 0;
		z-index: 1;
		cursor: pointer;
		/* fallback for browsers without color-mix */
		background: rgba(26, 23, 20, 0.65);
		background: color-mix(in srgb, var(--ink) 65%, transparent);
		-webkit-backdrop-filter: blur(8px) saturate(120%);
		backdrop-filter: blur(8px) saturate(120%);
	}

	.panel {
		position: relative;
		z-index: 2;
		width: min(680px, 100%);
		max-height: min(78dvh, 720px);
		display: flex;
		flex-direction: column;
		background: var(--canvas);
		border: 1px solid var(--ink);
		box-shadow:
			0 30px 80px -30px rgba(26, 23, 20, 0.55),
			0 30px 80px -30px color-mix(in srgb, var(--ink) 70%, transparent);
		animation: rise var(--dur) var(--ease-out);
	}

	@keyframes rise {
		from {
			transform: translateY(8px);
			opacity: 0;
		}
		to {
			transform: translateY(0);
			opacity: 1;
		}
	}

	.panel header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.9rem 1.2rem;
		border-bottom: 1px solid var(--rule);
	}

	.title-row {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		color: var(--ink);
	}

	.title-row svg {
		color: var(--accent);
	}

	.title-row h2 {
		margin: 0;
		font-family: var(--font-display);
		font-style: italic;
		font-size: var(--step-1);
		color: var(--ink);
		letter-spacing: var(--tracking-tight);
		font-weight: 400;
	}

	.panel header > button {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.3rem 0.6rem;
		font-size: var(--step--1);
		color: var(--ink-soft);
		border: 1px solid var(--rule);
		border-radius: 2px;
		transition: color var(--dur-fast) var(--ease-out),
			border-color var(--dur-fast) var(--ease-out);
	}

	.panel header > button:hover {
		color: var(--accent);
		border-color: var(--accent);
	}

	.panel header > button kbd {
		font-family: var(--font-mono);
		font-size: var(--step--2);
		color: var(--ink-faint);
		background: var(--canvas-soft);
		padding: 0.05rem 0.35rem;
		border-radius: 2px;
		letter-spacing: 0.06em;
	}

	.input-row {
		position: relative;
		padding: 1.2rem 1.4rem 0.4rem;
		border-bottom: 1px solid var(--rule);
	}

	.input-row input {
		width: 100%;
		font-family: var(--font-display);
		font-style: italic;
		font-size: clamp(1.6rem, 1.4rem + 1.4vw, 2.4rem);
		line-height: 1.1;
		letter-spacing: var(--tracking-tight);
		color: var(--ink);
		background: transparent;
		border: 0;
		padding: 0.2rem 0 0.6rem;
		outline: none;
	}

	.input-row input::placeholder {
		color: var(--ink-faint);
		opacity: 1;
	}

	.input-row input::-webkit-search-cancel-button {
		appearance: none;
	}

	.input-row .status {
		position: absolute;
		right: 1.4rem;
		bottom: 0.6rem;
		font-family: var(--font-mono);
		font-size: var(--step--2);
		text-transform: uppercase;
		letter-spacing: var(--tracking-caps);
		color: var(--ink-faint);
	}

	.results-region {
		flex: 1;
		overflow-y: auto;
		overscroll-behavior: contain;
	}

	#search-results {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	#search-results li {
		border-bottom: 1px solid var(--rule);
	}

	#search-results li a {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 0.3rem;
		padding: 1rem 1.4rem;
		color: var(--ink);
		transition: background var(--dur-fast) var(--ease-out);
	}

	#search-results li:hover a,
	#search-results li.active a {
		background: var(--canvas-soft);
	}

	#search-results li.active a {
		border-left: 2px solid var(--accent);
		padding-left: calc(1.4rem - 2px);
	}

	.result-meta {
		font-family: var(--font-body);
		font-size: var(--step--2);
		text-transform: uppercase;
		letter-spacing: var(--tracking-caps);
		color: var(--ink-faint);
	}

	.result-title {
		font-family: var(--font-display);
		font-size: var(--step-2);
		line-height: 1.15;
		letter-spacing: var(--tracking-tight);
		color: var(--ink);
	}

	#search-results li:hover .result-title,
	#search-results li.active .result-title {
		color: var(--accent);
	}

	.result-excerpt {
		font-size: var(--step--1);
		line-height: 1.55;
		color: var(--ink-soft);
	}

	.result-excerpt :global(mark) {
		background: var(--marker-soft);
		color: var(--ink);
		padding: 0 0.15em;
		font-style: italic;
	}

	.result-path {
		font-family: var(--font-mono);
		font-size: var(--step--2);
		color: var(--ink-faint);
		letter-spacing: 0.02em;
	}

	.state {
		padding: 2.2rem 1.4rem;
	}

	.hint-title {
		font-family: var(--font-display);
		font-style: italic;
		font-size: var(--step-3);
		line-height: 1.1;
		letter-spacing: var(--tracking-tight);
		color: var(--ink);
		margin: 0 0 0.6rem;
	}

	.hint-body {
		font-size: var(--step-0);
		line-height: 1.5;
		color: var(--ink-soft);
		max-width: 38ch;
	}

	.hint-body code {
		font-family: var(--font-mono);
		font-size: 0.92em;
		background: var(--canvas-soft);
		padding: 0.1em 0.4em;
		color: var(--accent);
	}

	.chip {
		display: inline-flex;
		align-items: center;
		padding: 0.1rem 0.5rem;
		margin: 0.15rem 0.1rem;
		font-family: var(--font-mono);
		font-size: var(--step--1);
		color: var(--accent);
		background: var(--canvas-soft);
		border: 1px solid var(--rule);
		border-radius: 2px;
		transition: background var(--dur-fast) var(--ease-out),
			border-color var(--dur-fast) var(--ease-out);
	}

	.chip:hover {
		background: var(--marker-soft);
		border-color: var(--accent);
	}

	.legend {
		display: flex;
		gap: 1.4rem;
		flex-wrap: wrap;
		padding: 0.7rem 1.4rem;
		border-top: 1px solid var(--rule);
		font-family: var(--font-body);
		font-size: var(--step--2);
		text-transform: uppercase;
		letter-spacing: var(--tracking-caps);
		color: var(--ink-faint);
		background: var(--canvas-soft);
	}

	.legend kbd {
		font-family: var(--font-mono);
		font-size: var(--step--2);
		color: var(--ink-soft);
		background: var(--canvas);
		border: 1px solid var(--rule);
		padding: 0.05rem 0.4rem;
		border-radius: 2px;
		margin-right: 0.35rem;
		letter-spacing: 0;
	}

	@media (max-width: 540px) {
		.legend {
			display: none;
		}
		.input-row input {
			font-size: var(--step-2);
		}
	}
</style>
