---
interface Props {
	cite?: string;
}
const { cite } = Astro.props;
---

<blockquote class="pull">
	<span class="open" aria-hidden="true">"</span>
	<p><slot /></p>
	{cite && <cite>— {cite}</cite>}
</blockquote>

<style>
	.pull {
		position: relative;
		font-family: var(--font-display);
		font-style: italic;
		font-size: var(--step-3);
		line-height: 1.25;
		letter-spacing: var(--tracking-tight);
		color: var(--ink);
		margin: 2.4em 0;
		padding: 1em 0;
		border-top: 1px solid var(--rule);
		border-bottom: 1px solid var(--rule);
	}

	.open {
		position: absolute;
		left: -0.3em;
		top: -0.25em;
		font-size: 5em;
		line-height: 1;
		color: var(--marker);
	}

	.pull p {
		max-width: 30ch;
	}

	cite {
		display: block;
		margin-top: 0.6em;
		font-family: var(--font-body);
		font-style: normal;
		font-size: var(--step--1);
		color: var(--ink-faint);
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
	}
</style>
