---
/**
 * "How to choose an adapter" — a decision table that feels like a magazine
 * comparison column. Helps a developer self-select in 10 seconds.
 */

interface Row {
	scenario: string;
	pick: string;
	pickSlug: string;
	why: string;
}

const rows: Row[] = [
	{
		scenario: "Local development, zero infra",
		pick: "SQLite",
		pickSlug: "sqlite",
		why: "A file. WAL mode. Works on every laptop.",
	},
	{
		scenario: "Caching in production",
		pick: "Redis",
		pickSlug: "redis",
		why: "Sub-millisecond reads. Battle-tested. Cluster-ready.",
	},
	{
		scenario: "Durable KV alongside your relational data",
		pick: "PostgreSQL",
		pickSlug: "postgres",
		why: "One database to back up. Transactions if you need them.",
	},
	{
		scenario: "Document-shaped values, large blobs",
		pick: "MongoDB",
		pickSlug: "mongo",
		why: "BSON envelopes and GridFS for >16 MB items.",
	},
	{
		scenario: "Edge / managed AWS",
		pick: "DynamoDB",
		pickSlug: "dynamo",
		why: "Native TTL attribute, no server to operate.",
	},
	{
		scenario: "Embedded, on-disk, no daemon",
		pick: "RocksDB",
		pickSlug: "rocksdb",
		why: "LSM tree with compression and lazy expiration built in.",
	},
];
---

<section class="matrix">
	<header>
		<p class="kicker">Editor's pick</p>
		<h2>Which adapter for <em>which job?</em></h2>
		<p class="lede">
			A short, opinionated table. Read the row that matches the situation
			you're staring at right now.
		</p>
	</header>

	<table>
		<thead>
			<tr>
				<th scope="col">If you need…</th>
				<th scope="col">Reach for</th>
				<th scope="col">Because</th>
			</tr>
		</thead>
		<tbody>
			{rows.map((row) => (
				<tr>
					<th scope="row">{row.scenario}</th>
					<td>
						<a href={`/adapters/${row.pickSlug}/`}>
							<span class="name">{row.pick}</span>
							<span class="arr" aria-hidden="true">→</span>
						</a>
					</td>
					<td class="why">{row.why}</td>
				</tr>
			))}
		</tbody>
	</table>
</section>

<style>
	.matrix {
		max-width: 1320px;
		margin: 0 auto;
		padding: clamp(3rem, 7vw, 5.5rem) var(--margin);
	}

	header {
		max-width: 38rem;
		margin-bottom: clamp(1.6rem, 4vw, 2.6rem);
	}

	.kicker {
		font-family: var(--font-body);
		font-size: var(--step--2);
		text-transform: uppercase;
		letter-spacing: var(--tracking-caps);
		color: var(--ink-faint);
		margin-bottom: 0.8rem;
	}

	h2 {
		font-family: var(--font-display);
		font-size: var(--step-4);
		line-height: 1.05;
		letter-spacing: var(--tracking-display);
	}

	h2 em {
		font-style: italic;
		color: var(--accent);
	}

	.lede {
		margin-top: 1rem;
		font-size: var(--step-0);
		color: var(--ink-soft);
		line-height: 1.55;
	}

	table {
		width: 100%;
		border-collapse: collapse;
		font-size: var(--step--1);
	}

	thead th {
		text-align: left;
		font-family: var(--font-body);
		font-weight: 500;
		font-size: var(--step--2);
		text-transform: uppercase;
		letter-spacing: var(--tracking-caps);
		color: var(--ink-soft);
		border-bottom: 1px solid var(--ink);
		padding: 0.8rem 1rem 0.8rem 0;
	}

	tbody th,
	tbody td {
		padding: 1.1rem 1rem 1.1rem 0;
		border-bottom: 1px solid var(--rule);
		vertical-align: top;
	}

	tbody th {
		font-family: var(--font-body);
		font-weight: 400;
		font-size: var(--step-0);
		color: var(--ink);
		text-align: left;
		width: 36%;
	}

	tbody td a {
		display: inline-flex;
		align-items: baseline;
		gap: 0.4rem;
		color: var(--ink);
		border-bottom: 1px solid var(--rule);
		transition: border-color var(--dur-fast) var(--ease-out);
	}

	tbody td a:hover {
		border-bottom-color: var(--accent);
	}

	tbody td a:hover .arr {
		color: var(--accent);
		transform: translateX(0.2em);
	}

	.name {
		font-family: var(--font-display);
		font-size: var(--step-2);
		letter-spacing: var(--tracking-tight);
	}

	.arr {
		font-family: var(--font-display);
		color: var(--ink-faint);
		transition: color var(--dur-fast) var(--ease-out),
			transform var(--dur-fast) var(--ease-out);
	}

	td.why {
		color: var(--ink-soft);
		line-height: 1.55;
		width: 38%;
	}

	@media (max-width: 720px) {
		table thead {
			display: none;
		}
		tbody th,
		tbody td {
			display: block;
			width: 100%;
			padding: 0.4rem 0;
		}
		tbody tr {
			display: block;
			padding: 1.2rem 0;
			border-bottom: 1px solid var(--rule);
		}
		tbody th {
			font-family: var(--font-body);
			font-size: var(--step--2);
			text-transform: uppercase;
			letter-spacing: var(--tracking-caps);
			color: var(--ink-faint);
		}
	}
</style>
