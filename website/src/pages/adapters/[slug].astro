---
import { getCollection, render } from "astro:content";
import DocsLayout from "~/layouts/DocsLayout.astro";
import { tierLabel } from "~/content/nav";

export async function getStaticPaths() {
	const entries = await getCollection("adapters");
	return entries.map((entry) => ({
		params: { slug: entry.data.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const editUrl = `https://github.com/ambicuity/storely/edit/main/${entry.data.source}/README.md`;
---

<DocsLayout
	title={entry.data.title}
	description={entry.data.tagline}
	section={`Adapter · ${tierLabel[entry.data.tier]}`}
	headings={headings}
	editUrl={editUrl}
>
	<div class="callout">
		<dl>
			<div>
				<dt>npm</dt>
				<dd><code>{entry.data.npm}</code></dd>
			</div>
			<div>
				<dt>Tier</dt>
				<dd>{tierLabel[entry.data.tier]}</dd>
			</div>
			<div>
				<dt>Source</dt>
				<dd>
					<a href={`https://github.com/ambicuity/storely/tree/main/${entry.data.source}`} rel="noopener">
						{entry.data.source}
					</a>
				</dd>
			</div>
		</dl>
		<p class="tagline">{entry.data.tagline}</p>
	</div>

	<Content />
</DocsLayout>

<style>
	.callout {
		margin-bottom: 2.4rem;
		padding: 1.4rem 0 1.6rem;
		border-top: 1px solid var(--rule);
		border-bottom: 1px solid var(--rule);
	}

	.callout dl {
		display: flex;
		gap: 2.4rem;
		flex-wrap: wrap;
		margin: 0 0 0.8rem;
	}

	.callout dt {
		font-family: var(--font-body);
		font-size: var(--step--2);
		text-transform: uppercase;
		letter-spacing: var(--tracking-caps);
		color: var(--ink-faint);
		margin-bottom: 0.2rem;
	}

	.callout dd {
		margin: 0;
		font-size: var(--step--1);
		color: var(--ink);
	}

	.callout dd code {
		font-family: var(--font-mono);
		color: var(--accent);
	}

	.callout dd a {
		color: var(--ink);
		border-bottom: 1px solid var(--rule);
	}

	.callout .tagline {
		font-family: var(--font-display);
		font-style: italic;
		font-size: var(--step-2);
		line-height: 1.3;
		letter-spacing: var(--tracking-tight);
		color: var(--ink);
		max-width: 40rem;
	}
</style>
