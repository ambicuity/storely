---
import MarketingLayout from "~/layouts/MarketingLayout.astro";
import Hero from "~/components/Hero.astro";
import StatsStrip from "~/components/StatsStrip.astro";
import InstallSnippet from "~/components/InstallSnippet.astro";
import Manifesto from "~/components/Manifesto.astro";
import CodeTabs from "~/components/CodeTabs.astro";
import DecisionMatrix from "~/components/DecisionMatrix.astro";
import AdapterGrid from "~/components/AdapterGrid.astro";
import PullQuote from "~/components/PullQuote.astro";
import Capabilities from "~/components/Capabilities.astro";
---

<MarketingLayout
	title="Storely — Simple key-value storage, for every backend you actually use."
	description="A small interface over Redis, Postgres, SQLite, Mongo, Valkey and seven more backends. TTL, namespaces, pluggable serialization, encryption, compression — without the framework tax."
>
	<Hero />

	<StatsStrip />

	<section class="install-strip">
		<div class="inner">
			<p class="kicker">Install</p>
			<InstallSnippet command="npm install @ambicuity/storely" label="One line" />
			<p class="hint">
				Storage adapters install separately — <a href="/adapters/">browse the directory</a>.
			</p>
		</div>
	</section>

	<Manifesto />

	<CodeTabs />

	<DecisionMatrix />

	<section class="directory">
		<div class="inner">
			<header>
				<p class="kicker">Volume of adapters</p>
				<h2>Twelve backends, <em>three tiers</em> of maturity.</h2>
				<p class="lede">
					Choose based on what you can operate. Production-ready adapters are
					hardened in live deployments. Beta is feature-complete but awaiting
					load tests. Experimental is for early integration work — do not put
					traffic on these yet.
				</p>
			</header>
			<AdapterGrid />
		</div>
	</section>

	<section class="quote">
		<div class="inner">
			<PullQuote cite="Storely 1.0.0 · Editor's note">
				Storage should be the part of your stack you forget about. Not the part
				you re-learn every time you change databases.
			</PullQuote>
		</div>
	</section>

	<Capabilities />
</MarketingLayout>

<style>
	.install-strip {
		border-bottom: 1px solid var(--rule);
		padding: 2rem 0;
		background: var(--canvas);
	}

	.install-strip .inner {
		max-width: 1320px;
		margin: 0 auto;
		padding: 0 var(--margin);
		display: flex;
		align-items: center;
		gap: 1.6rem;
		flex-wrap: wrap;
	}

	.install-strip .kicker {
		font-family: var(--font-body);
		font-size: var(--step--2);
		text-transform: uppercase;
		letter-spacing: var(--tracking-caps);
		color: var(--ink-faint);
	}

	.install-strip .hint {
		font-size: var(--step--1);
		color: var(--ink-soft);
	}

	.install-strip .hint a {
		color: var(--accent);
		border-bottom: 1px solid var(--rule);
	}

	.directory {
		padding: clamp(3rem, 7vw, 6rem) 0;
		background: linear-gradient(to bottom, var(--canvas) 0%, var(--canvas-soft) 100%);
	}

	.directory .inner {
		max-width: 1320px;
		margin: 0 auto;
		padding: 0 var(--margin);
	}

	.directory header {
		max-width: 36rem;
		margin-bottom: 1.4rem;
	}

	.directory .kicker {
		font-family: var(--font-body);
		font-size: var(--step--2);
		text-transform: uppercase;
		letter-spacing: var(--tracking-caps);
		color: var(--ink-faint);
		margin-bottom: 0.8rem;
	}

	.directory h2 {
		font-family: var(--font-display);
		font-size: var(--step-4);
		line-height: 1.05;
		letter-spacing: var(--tracking-display);
		color: var(--ink);
	}

	.directory h2 em {
		font-style: italic;
		color: var(--accent);
	}

	.directory .lede {
		margin-top: 0.9rem;
		font-size: var(--step-0);
		color: var(--ink-soft);
		max-width: 38rem;
		line-height: 1.55;
	}

	.quote {
		background: var(--canvas-soft);
		padding: clamp(3rem, 7vw, 5rem) 0;
	}

	.quote .inner {
		max-width: 1320px;
		margin: 0 auto;
		padding: 0 var(--margin);
	}
</style>
