---
import { getEntry, render } from "astro:content";
import DocsLayout from "~/layouts/DocsLayout.astro";

const entry = await getEntry("docs", "third-party");
if (!entry) throw new Error("third-party doc missing");
const { Content, headings } = await render(entry);
---

<DocsLayout
	title={entry.data.title}
	description={entry.data.description}
	section="Project"
	headings={headings}
	editUrl="https://github.com/ambicuity/storely/edit/main/website/src/content/docs/third-party.md"
>
	<Content />
</DocsLayout>
