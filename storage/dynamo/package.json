{
  "name": "@ambicuity/dynamo",
  "version": "1.0.2",
  "description": "DynamoDB storage adapter for Storely",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "pnpm build",
    "lint": "biome check --write --error-on-warnings",
    "lint:ci": "biome check --error-on-warnings",
    "test": "pnpm lint && vitest run --coverage",
    "test:ci": "pnpm lint:ci && vitest --run --sequence.setupFiles=list --coverage",
    "clean": "rimraf ./node_modules ./coverage ./dist"
  },
  "keywords": [
    "dynamo",
    "dynamodb",
    "storely",
    "storage",
    "adapter",
    "key",
    "value",
    "store",
    "cache",
    "ttl"
  ],
  "author": "Ritesh Rana <contact@riteshrana.engineer>",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.958.0",
    "@aws-sdk/lib-dynamodb": "^3.958.0",
    "hookified": "^2.0.0"
  },
  "devDependencies": {
    "@ambicuity/test-suite": "workspace:^"
  },
  "peerDependencies": {
    "@ambicuity/core": "workspace:^"
  },
  "tsd": {
    "directory": "test"
  },
  "files": [
    "dist",
    "LICENSE"
  ]
}
