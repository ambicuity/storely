{
  "name": "@ambicuity/mono-repo",
  "version": "1.0.1",
  "type": "module",
  "description": "Storely Mono Repo",
  "author": "Ritesh Rana <contact@riteshrana.engineer>",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">= 20"
  },
  "scripts": {
    "build:storely": "pnpm recursive --filter=@ambicuity/storely-core run build",
    "build": "pnpm build:storely && pnpm recursive --filter '!@ambicuity/storely-core' run build",
    "build:list": "pnpm build:storely && pnpm --filter '!@ambicuity/storely-core' --workspace-concurrency 1 -r build",
    "test": "pnpm -r test",
    "test:list": "pnpm -r --workspace-concurrency 1 test",
    "test:ci": "pnpm -r test:ci",
    "test:services:start": "chmod +x ./scripts/test-services-start.sh && ./scripts/test-services-start.sh",
    "test:services:stop": "chmod +x ./scripts/test-services-stop.sh && ./scripts/test-services-stop.sh",
    "website:build": "pnpm recursive --filter @ambicuity/website run website:build",
    "website:serve": "pnpm recursive --filter @ambicuity/website run website:serve",
    "clean": "rimraf node_modules && pnpm recursive run clean",
    "clean:lockfile": "rimraf pnpm-lock.yaml",
    "clean:all": "pnpm clean && pnpm clean:lockfile",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version && pnpm tsx scripts/version-sync.ts",
    "version:sync": "pnpm tsx scripts/version-sync.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@changesets/cli": "^2.27.0",
    "@faker-js/faker": "^10.2.0",
    "@ambicuity/mongo": "workspace:*",
    "@ambicuity/mysql": "workspace:*",
    "@ambicuity/postgres": "workspace:*",
    "@ambicuity/redis": "workspace:*",
    "@ambicuity/rocksdb": "workspace:*",
    "@ambicuity/sqlite": "workspace:*",
    "@ambicuity/valkey": "workspace:*",
    "@ambicuity/storely-core": "workspace:*",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.18",
    "js-yaml": "^4.1.1",
    "rimraf": "^6.1.2",
    "tsd": "^0.33.0",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "msgpackr-extract",
      "protobufjs",
      "sqlite3",
      "sqlite325h",
      "unrs-resolver"
    ],
    "overrides": {
      "tar@<7.5.9": ">=7.5.9"
    }
  }
}
